---
interface Props {
  compact?: boolean;
  formId?: string;
}

const { compact = false, formId = "newsletter-form" } = Astro.props;
const uniqueId = `${formId}-${Math.random().toString(36).substring(7)}`;
---

<div class={compact ? "" : "text-center"}>
  {!compact && (
    <h3 class="text-lg font-bold mb-2">Get new recipes in your inbox</h3>
    <p class="text-gray-mid text-sm mb-4">No spam. Just easy, delicious recipes. Unsubscribe anytime.</p>
  )}

  <form
    id={uniqueId}
    class={`newsletter-form flex gap-2 ${compact ? "" : "max-w-md mx-auto"}`}
    data-newsletter-form
  >
    <input
      type="email"
      name="email"
      placeholder="you@email.com"
      required
      aria-label="Email address"
      class="newsletter-input flex-1 px-4 py-2 border border-gray-border rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-coral focus:border-transparent bg-white"
    />
    <button
      type="submit"
      class="newsletter-button bg-coral text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-coral-dark transition-colors cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed"
    >
      <span class="button-text">Subscribe</span>
    </button>
  </form>

  <!-- Success/Error Messages -->
  <div class="newsletter-message mt-3 text-sm hidden">
    <p class="success-message hidden text-green font-medium">🎉 Welcome! Check your email to confirm.</p>
    <p class="error-message hidden text-red-600 font-medium">Something went wrong. Please try again.</p>
    <p class="existing-message hidden text-gray-mid">You're already subscribed!</p>
  </div>
</div>

<script>
  // Newsletter form handler
  document.addEventListener('DOMContentLoaded', () => {
    const forms = document.querySelectorAll('[data-newsletter-form]');

    forms.forEach(form => {
      if (!(form instanceof HTMLFormElement)) return;

      const emailInput = form.querySelector('input[type="email"]') as HTMLInputElement;
      const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const buttonText = submitButton?.querySelector('.button-text') as HTMLSpanElement;
      const messageContainer = form.nextElementSibling as HTMLElement;
      const successMessage = messageContainer?.querySelector('.success-message') as HTMLElement;
      const errorMessage = messageContainer?.querySelector('.error-message') as HTMLElement;
      const existingMessage = messageContainer?.querySelector('.existing-message') as HTMLElement;

      // Email validation regex
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        // Validate email format
        const email = emailInput.value.trim();
        if (!emailRegex.test(email)) {
          emailInput.setCustomValidity('Please enter a valid email address');
          emailInput.reportValidity();
          return;
        }

        // Clear any previous messages
        emailInput.setCustomValidity('');
        messageContainer?.classList.add('hidden');
        successMessage?.classList.add('hidden');
        errorMessage?.classList.add('hidden');
        existingMessage?.classList.add('hidden');

        // Update button state
        submitButton.disabled = true;
        const originalText = buttonText.textContent;
        buttonText.textContent = 'Subscribing...';

        try {
          // Submit to Buttondown
          const response = await fetch('https://api.buttondown.email/v1/subscribers', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              // Note: In production, you should proxy this through your own API
              // to avoid exposing your API key. For now, using the embedded form endpoint.
            },
            body: JSON.stringify({
              email: email,
              tags: ['cookthis-website']
            })
          });

          // Fallback to form submission if API fails
          if (!response.ok) {
            // Use the embedded form endpoint as fallback
            const formData = new FormData();
            formData.append('email', email);

            const embedResponse = await fetch('https://buttondown.com/api/emails/embed-subscribe/cookthis', {
              method: 'POST',
              body: formData,
              mode: 'no-cors' // Buttondown embedded endpoint doesn't support CORS
            });

            // Since no-cors doesn't give us response details, assume success
            handleSuccess();
          } else {
            handleSuccess();
          }

        } catch (error) {
          console.error('Newsletter subscription error:', error);

          // Try the embedded form endpoint as final fallback
          try {
            const formData = new FormData();
            formData.append('email', email);

            await fetch('https://buttondown.com/api/emails/embed-subscribe/cookthis', {
              method: 'POST',
              body: formData,
              mode: 'no-cors'
            });

            // Assume success since no-cors doesn't return response
            handleSuccess();
          } catch (fallbackError) {
            handleError();
          }
        }

        function handleSuccess() {
          // Show success message
          messageContainer?.classList.remove('hidden');
          successMessage?.classList.remove('hidden');

          // Reset form
          form.reset();

          // Update button
          buttonText.textContent = 'Subscribed!';
          submitButton.classList.add('bg-green', 'hover:bg-green');
          submitButton.classList.remove('bg-coral', 'hover:bg-coral-dark');

          // Store in localStorage to remember subscription
          localStorage.setItem('cookthis_newsletter_subscribed', 'true');
          localStorage.setItem('cookthis_newsletter_email', email);

          // Reset button after delay
          setTimeout(() => {
            buttonText.textContent = originalText || 'Subscribe';
            submitButton.classList.remove('bg-green', 'hover:bg-green');
            submitButton.classList.add('bg-coral', 'hover:bg-coral-dark');
            submitButton.disabled = false;
          }, 3000);
        }

        function handleError() {
          // Show error message
          messageContainer?.classList.remove('hidden');
          errorMessage?.classList.remove('hidden');

          // Reset button
          buttonText.textContent = originalText || 'Subscribe';
          submitButton.disabled = false;
        }
      });

      // Check if user already subscribed (from localStorage)
      const isSubscribed = localStorage.getItem('cookthis_newsletter_subscribed');
      const subscribedEmail = localStorage.getItem('cookthis_newsletter_email');

      if (isSubscribed && subscribedEmail) {
        // Pre-fill email if user was previously subscribed
        emailInput.placeholder = 'You\'re subscribed!';
      }
    });
  });

  // Handle smooth scroll to newsletter form when clicking Subscribe in nav
  document.addEventListener('DOMContentLoaded', () => {
    const subscribeLinks = document.querySelectorAll('a[href="#newsletter"]');

    subscribeLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const newsletter = document.querySelector('#newsletter, [data-newsletter-form]');
        if (newsletter) {
          newsletter.scrollIntoView({ behavior: 'smooth', block: 'center' });

          // Focus the email input
          const input = newsletter.querySelector('input[type="email"]') as HTMLInputElement;
          setTimeout(() => input?.focus(), 500);
        }
      });
    });
  });
</script>

<style>
  /* Loading animation */
  .newsletter-button:disabled .button-text::after {
    content: '';
    animation: dots 1.5s infinite;
  }

  @keyframes dots {
    0%, 20% { content: ''; }
    40% { content: '.'; }
    60% { content: '..'; }
    80%, 100% { content: '...'; }
  }

  /* Success animation */
  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .newsletter-message:not(.hidden) {
    animation: slideDown 0.3s ease-out;
  }
</style>
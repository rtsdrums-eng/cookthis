---
// Search component using Pagefind
---

<div class="search-container">
  <button
    id="search-button"
    class="search-trigger"
    aria-label="Search recipes"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"></circle>
      <path d="m21 21-4.35-4.35"></path>
    </svg>
    <span class="hidden sm:inline">Search</span>
  </button>
</div>

<!-- Search Modal -->
<div id="search-modal" class="search-modal hidden">
  <div class="search-modal-content">
    <div class="search-header">
      <div id="searchbox"></div>
      <button id="close-search" class="close-button" aria-label="Close search">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div id="searchresults"></div>
  </div>
</div>

<style>
  .search-container {
    display: flex;
    align-items: center;
  }

  .search-trigger {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    background: transparent;
    border: 1px solid var(--color-gray-border);
    border-radius: 8px;
    color: var(--color-gray-mid);
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }

  .search-trigger:hover {
    color: var(--color-charcoal);
    border-color: var(--color-coral);
  }

  /* Modal Styles */
  .search-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 10vh;
  }

  .search-modal.hidden {
    display: none;
  }

  .search-modal-content {
    background: white;
    border-radius: 16px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    width: 90%;
    max-width: 650px;
    max-height: 70vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .search-header {
    display: flex;
    align-items: center;
    padding: 20px;
    border-bottom: 1px solid var(--color-gray-border);
    gap: 12px;
  }

  #searchbox {
    flex: 1;
  }

  .close-button {
    padding: 8px;
    background: transparent;
    border: none;
    color: var(--color-gray-mid);
    cursor: pointer;
    border-radius: 8px;
    transition: all 0.2s;
  }

  .close-button:hover {
    background: var(--color-gray-light);
    color: var(--color-charcoal);
  }

  #searchresults {
    flex: 1;
    overflow-y: auto;
    padding: 20px;
  }

  /* Pagefind UI Customization */
  :global(.pagefind-ui__search-input) {
    width: 100%;
    padding: 12px 16px;
    border: 2px solid var(--color-gray-border);
    border-radius: 8px;
    font-size: 16px;
    font-family: var(--font-sans);
    background: white;
    transition: border-color 0.2s;
  }

  :global(.pagefind-ui__search-input:focus) {
    outline: none;
    border-color: var(--color-coral);
  }

  :global(.pagefind-ui__search-clear) {
    top: 50%;
    transform: translateY(-50%);
    right: 12px;
  }

  :global(.pagefind-ui__result) {
    border: 1px solid var(--color-gray-border);
    border-radius: 8px;
    padding: 16px;
    margin-bottom: 12px;
    transition: all 0.2s;
  }

  :global(.pagefind-ui__result:hover) {
    border-color: var(--color-coral);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  :global(.pagefind-ui__result-title) {
    font-size: 18px;
    font-weight: 600;
    color: var(--color-charcoal);
    margin-bottom: 4px;
  }

  :global(.pagefind-ui__result-link) {
    color: inherit;
    text-decoration: none;
  }

  :global(.pagefind-ui__result-link:hover .pagefind-ui__result-title) {
    color: var(--color-coral);
  }

  :global(.pagefind-ui__result-excerpt) {
    color: var(--color-gray-mid);
    font-size: 14px;
    line-height: 1.5;
  }

  :global(mark) {
    background: #FFF3E0;
    color: var(--color-charcoal);
    padding: 2px 4px;
    border-radius: 2px;
    font-weight: 500;
  }

  :global(.pagefind-ui__loading) {
    color: var(--color-gray-mid);
    font-size: 14px;
    text-align: center;
    padding: 20px;
  }

  :global(.pagefind-ui__message) {
    color: var(--color-gray-mid);
    font-size: 14px;
    text-align: center;
    padding: 40px 20px;
  }

  /* Keyboard shortcut hint */
  @media (min-width: 640px) {
    .search-trigger::after {
      content: "⌘K";
      margin-left: 8px;
      padding: 2px 6px;
      background: var(--color-gray-light);
      border-radius: 4px;
      font-size: 11px;
      font-weight: 600;
      color: var(--color-gray-mid);
    }
  }

  /* Mobile responsiveness */
  @media (max-width: 640px) {
    .search-modal {
      padding-top: 0;
      align-items: stretch;
    }

    .search-modal-content {
      width: 100%;
      max-width: 100%;
      height: 100vh;
      max-height: 100vh;
      border-radius: 0;
    }
  }
</style>

<script>
  // Initialize search functionality
  document.addEventListener('DOMContentLoaded', async () => {
    const searchButton = document.getElementById('search-button');
    const searchModal = document.getElementById('search-modal');
    const closeButton = document.getElementById('close-search');
    const searchBox = document.getElementById('searchbox');

    let searchInitialized = false;

    // Function to show search modal
    async function showSearch() {
      searchModal?.classList.remove('hidden');

      // Initialize Pagefind UI on first open
      if (!searchInitialized && searchBox) {
        try {
          // Load Pagefind UI dynamically
          const script = document.createElement('script');
          script.src = '/pagefind/pagefind-ui.js';
          await new Promise((resolve) => {
            script.onload = resolve;
            document.head.appendChild(script);
          });

          // Initialize after script loads
          // @ts-ignore
          new PagefindUI({
            element: '#searchbox',
            showSubResults: true,
            showImages: false,
            resetStyles: false,
            autofocus: true,
            placeholder: 'Search recipes, ingredients, instructions...'
          });

          searchInitialized = true;

          // Focus the input after initialization
          setTimeout(() => {
            const input = searchBox.querySelector('input');
            if (input instanceof HTMLInputElement) {
              input.focus();
            }
          }, 100);
        } catch (error) {
          console.error('Failed to load search:', error);
          searchBox.innerHTML = '<p style="color: var(--color-gray-mid); padding: 20px; text-align: center;">Search is only available in production build. Run `npm run build && npm run preview` to test search.</p>';
        }
      }

      // Focus input if already initialized
      if (searchInitialized) {
        const input = searchBox?.querySelector('input');
        if (input instanceof HTMLInputElement) {
          input.focus();
        }
      }
    }

    // Function to hide search modal
    function hideSearch() {
      searchModal?.classList.add('hidden');
    }

    // Event listeners
    searchButton?.addEventListener('click', showSearch);
    closeButton?.addEventListener('click', hideSearch);

    // Close on backdrop click
    searchModal?.addEventListener('click', (e) => {
      if (e.target === searchModal) {
        hideSearch();
      }
    });

    // Keyboard shortcuts
    document.addEventListener('keydown', (e) => {
      // Cmd/Ctrl + K to open search
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        showSearch();
      }

      // Escape to close
      if (e.key === 'Escape' && !searchModal?.classList.contains('hidden')) {
        hideSearch();
      }
    });
  });
</script>

<!-- Load Pagefind CSS -->
<link href="/pagefind/pagefind-ui.css" rel="stylesheet">
---
interface Props {
  title: string;
  description: string;
  slug: string;
  prepTime: string | number;
  cookTime: string | number;
  category: string;
  image?: string;
  imageAlt?: string;
  tags?: string[];
}

const { title, description, slug, prepTime, cookTime, category, image, imageAlt, tags = [] } = Astro.props;

// Generate placeholder image URL if no image provided
// Using Picsum Photos with a seed based on title for consistent images
const seed = (title || 'recipe').toLowerCase().replace(/\s+/g, '-');
const imageUrl = image || `https://picsum.photos/seed/${seed}/800/600`;

// Check if it's a quick recipe (30 minutes or less)
const totalTime = Number(cookTime) + Number(prepTime || 0);
const isQuick = totalTime <= 30;

// Check for special tags
const isVegetarian = tags.some(tag => tag.toLowerCase().includes('vegetarian') || tag.toLowerCase().includes('vegan'));
const isOnePan = tags.some(tag => tag.toLowerCase().includes('one-pan') || tag.toLowerCase().includes('sheet-pan'));
---

<a href={`/recipes/${slug}`} class="group block">
  <article class="recipe-card border border-gray-border rounded-xl overflow-hidden bg-white hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
    <div class="aspect-[16/10] overflow-hidden relative">
      <img
        src={imageUrl}
        alt={imageAlt || title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
      {/* Badges overlay */}
      <div class="absolute top-3 left-3 flex gap-2 flex-wrap">
        {isQuick && (
          <span class="badge-quick bg-white/95 backdrop-blur-sm px-2 py-1 rounded-full text-xs font-semibold text-coral flex items-center gap-1">
            ⚡ Quick
          </span>
        )}
        {isVegetarian && (
          <span class="badge-veg bg-white/95 backdrop-blur-sm px-2 py-1 rounded-full text-xs font-semibold text-green flex items-center gap-1">
            🥬 Veg
          </span>
        )}
        {isOnePan && (
          <span class="badge-one-pan bg-white/95 backdrop-blur-sm px-2 py-1 rounded-full text-xs font-semibold text-charcoal flex items-center gap-1">
            🍳 One-Pan
          </span>
        )}
      </div>
    </div>
    <div class="p-5">
      <span class="text-xs font-medium uppercase tracking-wide text-coral">{category}</span>
      <h3 class="text-lg font-bold mt-1 mb-2 group-hover:text-coral transition-colors">{title}</h3>
      <p class="text-gray-mid text-sm leading-relaxed mb-3 line-clamp-2">{description}</p>
      <div class="flex gap-3 text-xs text-gray-mid items-center">
        <span class="flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <path d="M12 6v6l4 2"/>
          </svg>
          {totalTime} min total
        </span>
        <span class="text-gray-border">•</span>
        <span>{prepTime ? `${prepTime} min prep` : 'No prep'}</span>
      </div>
    </div>
  </article>
</a>

---
interface Props {
  label?: string;
}

const { label = "Print Recipe" } = Astro.props;
---

<button
  class="print-btn no-print inline-flex items-center gap-2 px-4 py-2 text-sm font-medium border border-gray-border rounded-lg hover:bg-gray-light transition-colors cursor-pointer"
  onclick="window.print()"
>
  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <polyline points="6 9 6 2 18 2 18 9"></polyline>
    <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path>
    <rect x="6" y="14" width="12" height="8"></rect>
  </svg>
  {label}
</button>

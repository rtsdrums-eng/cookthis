---
import "../styles/global.css";
import NewsletterSignup from "../components/NewsletterSignup.astro";
import Search from "../components/Search.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "CookThis — No-Fluff Recipes for Real Life",
  description = "Easy, delicious, carefully curated recipes for couples and families. No ads, no life stories — just cook this.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-cream text-charcoal font-sans min-h-screen flex flex-col">
    <!-- Main content -->
    <main class="flex-1">
      <slot />
    </main>
  </body>
</html>

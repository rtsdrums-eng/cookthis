---
import BaseLayout from "../layouts/BaseLayout.astro";
import MinimalRecipeCard from "../components/MinimalRecipeCard.astro";
import { getCollection } from "astro:content";

const allRecipes = await getCollection("recipes", ({ data }) => !data.draft);
const recipes = allRecipes.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featuredRecipes = recipes.slice(0, 6);
---

<BaseLayout>
  <div class="minimal-layout">
    <!-- Hero Section - Ultra Minimal -->
    <section class="hero-section">
      <div class="hero-content">
        <h1 class="hero-title">cookthis</h1>
        <p class="hero-subtitle">Simple recipes. Beautiful food.</p>
      </div>
    </section>

    <!-- Navigation Bar -->
    <nav class="nav-bar">
      <div class="nav-container">
        <ul class="nav-links">
          <li><a href="/recipes" class="nav-link active">Recipes</a></li>
          <li><a href="/recipes/category/breakfast" class="nav-link">Breakfast</a></li>
          <li><a href="/recipes/category/lunch" class="nav-link">Lunch</a></li>
          <li><a href="/recipes/category/dinner" class="nav-link">Dinner</a></li>
          <li><a href="/about" class="nav-link">About</a></li>
        </ul>
        <button class="search-btn" onclick="openSearch()">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.35-4.35"/>
          </svg>
        </button>
      </div>
    </nav>

    <!-- Recipe Grid - Minimal Cards -->
    <section class="recipes-section">
      <div class="recipes-container">
        <div class="section-header">
          <h2 class="section-title">Latest</h2>
          <a href="/recipes" class="view-all">View all →</a>
        </div>

        <div class="recipes-grid">
          {featuredRecipes.map((recipe) => (
            <MinimalRecipeCard
              title={recipe.data.title}
              description={recipe.data.description}
              slug={recipe.id}
              prepTime={recipe.data.prepTime}
              cookTime={recipe.data.cookTime}
              category={recipe.data.category}
              image={recipe.data.image}
              imageAlt={recipe.data.imageAlt}
              tags={recipe.data.tags}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Newsletter Section - Minimal -->
    <section class="newsletter-section">
      <div class="newsletter-container">
        <h2 class="newsletter-title">Stay Updated</h2>
        <p class="newsletter-subtitle">New recipes delivered weekly</p>
        <form class="newsletter-form">
          <input
            type="email"
            placeholder="Your email address"
            class="email-input"
            required
          />
          <button type="submit" class="submit-btn">Subscribe</button>
        </form>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .minimal-layout {
    min-height: 100vh;
    background: #fafafa;
  }

  /* Hero Section */
  .hero-section {
    height: 50vh;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(to bottom, #fff, #fafafa);
    border-bottom: 1px solid #f0f0f0;
  }

  .hero-content {
    text-align: center;
  }

  .hero-title {
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 200;
    letter-spacing: -0.05em;
    margin-bottom: 0.5rem;
    color: #1a1a1a;
  }

  .hero-subtitle {
    font-size: 16px;
    color: #999;
    font-weight: 300;
    letter-spacing: 0.05em;
  }

  /* Navigation */
  .nav-bar {
    border-bottom: 1px solid #f0f0f0;
    background: white;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 60px;
  }

  .nav-links {
    display: flex;
    gap: 3rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    font-size: 14px;
    color: #666;
    text-decoration: none;
    font-weight: 400;
    letter-spacing: 0.03em;
    transition: color 0.3s ease;
  }

  .nav-link:hover,
  .nav-link.active {
    color: #1a1a1a;
  }

  .search-btn {
    background: none;
    border: none;
    color: #666;
    cursor: pointer;
    padding: 8px;
    transition: color 0.3s ease;
  }

  .search-btn:hover {
    color: #1a1a1a;
  }

  /* Recipes Section */
  .recipes-section {
    padding: 5rem 0;
  }

  .recipes-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 3rem;
  }

  .section-title {
    font-size: 2rem;
    font-weight: 300;
    letter-spacing: -0.02em;
    color: #1a1a1a;
  }

  .view-all {
    font-size: 14px;
    color: #999;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .view-all:hover {
    color: #666;
  }

  .recipes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
    gap: 3rem;
  }

  @media (max-width: 768px) {
    .recipes-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  /* Newsletter Section */
  .newsletter-section {
    background: white;
    border-top: 1px solid #f0f0f0;
    padding: 5rem 0;
  }

  .newsletter-container {
    max-width: 500px;
    margin: 0 auto;
    text-align: center;
    padding: 0 2rem;
  }

  .newsletter-title {
    font-size: 1.75rem;
    font-weight: 300;
    margin-bottom: 0.5rem;
    color: #1a1a1a;
  }

  .newsletter-subtitle {
    font-size: 14px;
    color: #999;
    margin-bottom: 2rem;
  }

  .newsletter-form {
    display: flex;
    gap: 1rem;
  }

  .email-input {
    flex: 1;
    padding: 0.75rem 1rem;
    border: 1px solid #e0e0e0;
    background: #fafafa;
    font-size: 14px;
    transition: all 0.3s ease;
  }

  .email-input:focus {
    outline: none;
    border-color: #999;
    background: white;
  }

  .submit-btn {
    padding: 0.75rem 2rem;
    background: #1a1a1a;
    color: white;
    border: none;
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: background 0.3s ease;
  }

  .submit-btn:hover {
    background: #333;
  }
</style>

<script>
  function openSearch() {
    const event = new KeyboardEvent('keydown', {
      key: 'k',
      metaKey: true
    });
    window.dispatchEvent(event);
  }
</script>
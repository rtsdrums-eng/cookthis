---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CopyButton from "../../components/CopyButton.astro";
import PrintButton from "../../components/PrintButton.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const recipes = await getCollection("recipes");
  return recipes.map((recipe) => ({
    params: { slug: recipe.id },
    props: { recipe },
  }));
}

const { recipe } = Astro.props;
const { Content } = await render(recipe);
const { title, description, author, prepTime, cookTime, totalTime, servings, category, image, imageAlt, date } = recipe.data;

const formattedDate = new Date(date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={`${title} — CookThis`} description={description}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <!-- Back link -->
    <a href="/recipes" class="no-print text-sm text-gray-mid hover:text-coral transition-colors mb-6 inline-block">
      &larr; All Recipes
    </a>

    <!-- Recipe header -->
    <header class="mb-8">
      <span class="text-xs font-medium uppercase tracking-wide text-coral">{category}</span>
      <h1 class="text-3xl md:text-4xl font-bold mt-2 mb-3">{title}</h1>
      <p class="text-gray-mid text-lg leading-relaxed">{description}</p>

      <!-- Meta info -->
      <div class="flex flex-wrap gap-4 mt-5 text-sm text-gray-mid">
        <div>
          <span class="font-medium text-charcoal">Prep:</span> {prepTime}
        </div>
        <div>
          <span class="font-medium text-charcoal">Cook:</span> {cookTime}
        </div>
        {totalTime && (
          <div>
            <span class="font-medium text-charcoal">Total:</span> {totalTime}
          </div>
        )}
        <div>
          <span class="font-medium text-charcoal">Servings:</span> {servings}
        </div>
      </div>

      <!-- Author & date -->
      <div class="flex items-center gap-3 mt-4 text-xs text-gray-mid">
        <span>By {author}</span>
        <span class="text-gray-border">|</span>
        <time datetime={date.toISOString()}>{formattedDate}</time>
      </div>
    </header>

    <!-- Hero image -->
    {image && (
      <div class="rounded-xl overflow-hidden mb-8 max-h-96">
        <img
          src={image}
          alt={imageAlt || title}
          class="w-full h-full object-cover"
        />
      </div>
    )}

    <!-- Action buttons -->
    <div class="no-print flex gap-3 mb-8">
      <CopyButton />
      <PrintButton />
    </div>

    <!-- Recipe content -->
    <div class="recipe-content prose prose-lg max-w-none">
      <Content />
    </div>
  </article>
</BaseLayout>

<style is:global>
  .recipe-content h2 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-gray-border);
  }

  .recipe-content ul {
    list-style: none;
    padding: 0;
  }

  .recipe-content ul li {
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-gray-border);
    font-size: 0.95rem;
  }

  .recipe-content ul li:last-child {
    border-bottom: none;
  }

  .recipe-content ol {
    list-style: none;
    padding: 0;
    counter-reset: steps;
  }

  .recipe-content ol li {
    counter-increment: steps;
    padding: 0.75rem 0;
    padding-left: 2.5rem;
    position: relative;
    font-size: 0.95rem;
    line-height: 1.7;
    border-bottom: 1px solid var(--color-gray-border);
  }

  .recipe-content ol li:last-child {
    border-bottom: none;
  }

  .recipe-content ol li::before {
    content: counter(steps);
    position: absolute;
    left: 0;
    top: 0.75rem;
    width: 1.75rem;
    height: 1.75rem;
    background: var(--color-coral);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 600;
  }

  /* Notes section */
  .recipe-content h2:last-of-type + p {
    background: var(--color-gray-light);
    padding: 1rem 1.25rem;
    border-radius: 0.5rem;
    font-size: 0.9rem;
    color: var(--color-gray-mid);
  }
</style>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CopyButton from "../../components/CopyButton.astro";
import PrintButton from "../../components/PrintButton.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const recipes = await getCollection("recipes");
  return recipes.map((recipe) => ({
    params: { slug: recipe.id },
    props: { recipe },
  }));
}

const { recipe } = Astro.props;
const { Content } = await render(recipe);
const { title, description, author, prepTime, cookTime, totalTime, servings, category, image, imageAlt, date } = recipe.data;

const formattedDate = new Date(date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={`${title} — CookThis`} description={description}>
  <article class="max-w-2xl mx-auto px-4 py-8">
    <!-- Back link -->
    <a href="/" class="no-print text-xs text-gray-400 hover:text-gray-600 transition-colors mb-4 inline-block">
      ← back
    </a>

    <!-- Recipe header - simplified -->
    <header class="mb-6">
      <h1 class="text-2xl font-semibold mb-2">{title}</h1>
      <p class="text-gray-600 text-sm leading-relaxed mb-3">{description}</p>

      <!-- Meta info - compact -->
      <div class="flex flex-wrap gap-3 text-xs text-gray-500">
        <span>{category}</span>
        <span>•</span>
        <span>prep: {prepTime} min</span>
        <span>•</span>
        <span>cook: {cookTime} min</span>
        <span>•</span>
        <span>serves {servings}</span>
      </div>
    </header>

    <!-- Hero image with strict sizing (3:2 aspect ratio) -->
    {image && (
      <div class="recipe-hero-image mb-6">
        <img
          src={image}
          alt={imageAlt || title}
          class="w-full h-full object-cover"
        />
      </div>
    )}

    <!-- Action buttons -->
    <div class="no-print flex gap-2 mb-6">
      <CopyButton />
      <PrintButton />
    </div>

    <!-- Recipe content -->
    <div class="recipe-content">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  /* Hero image with strict 3:2 aspect ratio */
  .recipe-hero-image {
    width: 100%;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: #f8f8f8;
    border-radius: 0.25rem;
  }
</style>

<style is:global>
  /* Simple, Notion-like typography */
  .recipe-content h2 {
    font-size: 1.125rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    color: #1a1a1a;
  }

  /* Ingredients - simple list */
  .recipe-content ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .recipe-content ul li {
    padding: 0.375rem 0;
    font-size: 0.875rem;
    color: #333;
    line-height: 1.5;
  }

  .recipe-content ul li::before {
    content: "•";
    color: #999;
    display: inline-block;
    width: 1rem;
    margin-right: 0.25rem;
  }

  /* Instructions - numbered steps */
  .recipe-content ol {
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: steps;
  }

  .recipe-content ol li {
    counter-increment: steps;
    padding: 0.5rem 0 0.5rem 1.75rem;
    position: relative;
    font-size: 0.875rem;
    line-height: 1.6;
    color: #333;
  }

  .recipe-content ol li::before {
    content: counter(steps) ".";
    position: absolute;
    left: 0;
    top: 0.5rem;
    color: #666;
    font-size: 0.875rem;
    font-weight: 500;
  }

  /* Notes section - subtle background */
  .recipe-content blockquote,
  .recipe-content h2:last-of-type + p,
  .recipe-content h2:last-of-type + ul {
    background: #f8f8f8;
    border-left: 2px solid #e0e0e0;
    padding: 0.75rem 1rem;
    margin: 1rem 0;
    font-size: 0.875rem;
    color: #666;
  }

  /* Remove excessive spacing */
  .recipe-content > * {
    margin-bottom: 1rem;
  }

  .recipe-content h2 + ul,
  .recipe-content h2 + ol {
    margin-top: 0.25rem;
  }
</style>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import MinimalRecipeCard from "../components/MinimalRecipeCard.astro";
import { getCollection } from "astro:content";

const allRecipes = await getCollection("recipes", ({ data }) => !data.draft);
// Sort by sortOrder if present, otherwise by date
const recipes = allRecipes.sort((a, b) => {
  // First check if both have sortOrder
  if (a.data.sortOrder !== undefined && b.data.sortOrder !== undefined) {
    return a.data.sortOrder - b.data.sortOrder;
  }
  // If only one has sortOrder, prioritize it
  if (a.data.sortOrder !== undefined) return -1;
  if (b.data.sortOrder !== undefined) return 1;
  // Fall back to date sorting (newest first)
  return b.data.date.valueOf() - a.data.date.valueOf();
});

// Pagination
const currentPage = 1;
const recipesPerPage = 9;
const totalPages = Math.ceil(recipes.length / recipesPerPage);
const paginatedRecipes = recipes.slice(0, recipesPerPage);
---

<BaseLayout>
  <div class="minimal-layout">
    <!-- Simplified Navigation Bar -->
    <nav class="nav-bar">
      <div class="nav-container">
        <a href="/" class="logo">cookthis</a>
        <div class="nav-newsletter-wrapper">
          <button class="mobile-mail-toggle" id="mobile-mail-toggle" aria-label="Newsletter">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="m22 7-10 5L2 7"/>
            </svg>
          </button>
          <form class="nav-newsletter-form" id="nav-newsletter-form">
            <input
              type="email"
              placeholder="enter your email"
              class="nav-email-input"
              required
            />
            <button type="submit" class="nav-submit-btn">subscribe</button>
          </form>
        </div>
      </div>
    </nav>

    <!-- Recipe Grid - 9 cards -->
    <section class="recipes-section">
      <div class="recipes-container">
        <div class="recipes-grid">
          {paginatedRecipes.map((recipe) => (
            <MinimalRecipeCard
              title={recipe.data.title}
              description={recipe.data.description}
              slug={recipe.id}
              prepTime={recipe.data.prepTime}
              cookTime={recipe.data.cookTime}
              category={recipe.data.category}
              tags={recipe.data.tags}
              image={recipe.data.image}
            />
          ))}
        </div>

        <!-- Pagination -->
        {totalPages > 1 && (
          <div class="pagination">
            <button class="page-arrow" disabled={currentPage === 1}>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M15 18l-6-6 6-6"/>
              </svg>
            </button>
            <span class="page-info">{currentPage} / {totalPages}</span>
            <button class="page-arrow" disabled={currentPage === totalPages}>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M9 18l6-6-6-6"/>
              </svg>
            </button>
          </div>
        )}
      </div>
    </section>

    <!-- Footer with Newsletter -->
    <footer class="footer">
      <div class="footer-container">
        <div class="newsletter-inline">
          <form class="newsletter-form" id="newsletter-form">
            <input
              type="email"
              placeholder="enter your email for weekly recipes"
              class="email-input"
              required
            />
            <button type="submit" class="submit-btn">subscribe</button>
          </form>
        </div>
        <div class="copyright">
          <p>© 2026 CookThis. All rights reserved.</p>
        </div>
      </div>
    </footer>
  </div>
</BaseLayout>

<style>
  .minimal-layout {
    min-height: 100vh;
    background: #fafafa;
    display: flex;
    flex-direction: column;
  }

  /* Navigation */
  .nav-bar {
    border-top: 2px solid #1a1a1a;
    border-bottom: 1px solid #f0f0f0;
    background: white;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 56px;
  }

  .logo {
    font-size: 1.25rem;
    font-weight: 400;
    color: #1a1a1a;
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  /* Navbar Newsletter Form */
  .nav-newsletter-form {
    display: flex;
    gap: 0.5rem;
  }

  .nav-email-input {
    padding: 0.5rem 0.75rem;
    border: 1px solid #e0e0e0;
    background: #fafafa;
    font-size: 13px;
    width: 200px;
    transition: all 0.3s ease;
    text-transform: lowercase;
  }

  .nav-email-input::placeholder {
    color: #999;
    text-transform: none;
  }

  .nav-email-input:focus {
    outline: none;
    border-color: #999;
    background: white;
  }

  .nav-submit-btn {
    padding: 0.5rem 1rem;
    background: #1a1a1a;
    color: white;
    border: none;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.03em;
    cursor: pointer;
    transition: background 0.3s ease;
    text-transform: lowercase;
  }

  .nav-submit-btn:hover:not(:disabled) {
    background: #333;
  }

  .nav-submit-btn:disabled {
    cursor: default;
    opacity: 0.8;
  }

  .nav-submit-btn.success {
    background: #4CAF50;
  }

  /* Mobile Mail Toggle */
  .nav-newsletter-wrapper {
    display: flex;
    align-items: center;
  }

  .mobile-mail-toggle {
    display: none;
    background: none;
    border: none;
    padding: 0.5rem;
    cursor: pointer;
    color: #666;
    transition: color 0.3s ease;
  }

  .mobile-mail-toggle:hover {
    color: #1a1a1a;
  }

  .mobile-mail-toggle svg {
    display: block;
  }

  /* Mobile Newsletter Styles */
  @media (max-width: 640px) {
    .nav-container {
      padding: 0 1rem;
    }

    .mobile-mail-toggle {
      display: block;
    }

    .nav-newsletter-form {
      position: absolute;
      right: 3rem;
      top: 50%;
      transform: translateY(-50%);
      opacity: 0;
      visibility: hidden;
      transition: all 0.3s ease;
      background: white;
      padding: 0.5rem;
      border-radius: 0.25rem;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .nav-newsletter-form.active {
      opacity: 1;
      visibility: visible;
    }

    .nav-email-input {
      width: 120px;
      font-size: 12px;
      padding: 0.4rem 0.5rem;
    }

    .nav-submit-btn {
      font-size: 11px;
      padding: 0.4rem 0.6rem;
    }

    /* Ensure form doesn't overlap logo */
    .nav-newsletter-wrapper {
      position: relative;
    }

    .logo {
      font-size: 1.1rem;
    }
  }

  /* Recipes Section */
  .recipes-section {
    flex: 1;
    padding: 3rem 0;
  }

  .recipes-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .recipes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-bottom: 3rem;
  }

  @media (max-width: 1024px) {
    .recipes-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .recipes-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  /* Pagination */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .page-arrow {
    background: none;
    border: 1px solid #e0e0e0;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    color: #666;
  }

  .page-arrow:hover:not(:disabled) {
    border-color: #999;
    color: #1a1a1a;
  }

  .page-arrow:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .page-info {
    font-size: 13px;
    color: #999;
    font-weight: 400;
    letter-spacing: 0.05em;
  }

  /* Footer */
  .footer {
    background: white;
    border-top: 1px solid #f0f0f0;
    padding: 3rem 0 2rem;
    margin-top: auto;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .newsletter-inline {
    margin-bottom: 2rem;
  }

  .newsletter-form {
    display: flex;
    gap: 1rem;
    max-width: 400px;
  }

  .email-input {
    flex: 1;
    padding: 0.625rem 1rem;
    border: 1px solid #e0e0e0;
    background: #fafafa;
    font-size: 13px;
    transition: all 0.3s ease;
    text-transform: lowercase;
  }

  .email-input::placeholder {
    color: #999;
    text-transform: none;
  }

  .email-input:focus {
    outline: none;
    border-color: #999;
    background: white;
  }

  .submit-btn {
    padding: 0.625rem 1.5rem;
    background: #1a1a1a;
    color: white;
    border: none;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: background 0.3s ease;
    text-transform: lowercase;
  }

  .submit-btn:hover:not(:disabled) {
    background: #333;
  }

  .submit-btn:disabled {
    cursor: default;
    opacity: 0.8;
  }

  .submit-btn.success {
    background: #4CAF50;
  }

  .copyright {
    padding-top: 1.5rem;
    border-top: 1px solid #f8f8f8;
  }

  .copyright p {
    font-size: 12px;
    color: #999;
  }
</style>

<script>
  // Handle newsletter form submissions with Buttondown
  document.addEventListener('DOMContentLoaded', () => {
    // Mobile mail toggle functionality
    const mobileMailToggle = document.getElementById('mobile-mail-toggle');
    const navForm = document.getElementById('nav-newsletter-form');

    if (mobileMailToggle && navForm) {
      mobileMailToggle.addEventListener('click', (e) => {
        e.stopPropagation();
        navForm.classList.toggle('active');

        // Focus email input when opened
        if (navForm.classList.contains('active')) {
          const emailInput = navForm.querySelector('input[type="email"]');
          if (emailInput) {
            setTimeout(() => emailInput.focus(), 100);
          }
        }
      });

      // Close form when clicking outside
      document.addEventListener('click', (e) => {
        if (!navForm.contains(e.target) && !mobileMailToggle.contains(e.target)) {
          navForm.classList.remove('active');
        }
      });

      // Close form when submitting
      navForm.addEventListener('submit', () => {
        setTimeout(() => {
          navForm.classList.remove('active');
        }, 100);
      });
    }
    async function handleNewsletterSubmit(form, emailInput, button) {
      const email = emailInput.value.trim();
      const originalText = button.textContent;

      // Disable button and show loading state
      button.disabled = true;
      button.textContent = 'subscribing...';

      try {
        // Submit to Buttondown embedded endpoint
        const formData = new FormData();
        formData.append('email', email);

        await fetch('https://buttondown.com/api/emails/embed-subscribe/cookthis', {
          method: 'POST',
          body: formData,
          mode: 'no-cors' // Buttondown embedded endpoint doesn't support CORS
        });

        // Since no-cors doesn't give us response details, assume success
        button.textContent = 'subscribed!';
        button.classList.add('success');
        emailInput.value = '';

        // Store subscription in localStorage
        localStorage.setItem('cookthis_newsletter_subscribed', 'true');
        localStorage.setItem('cookthis_newsletter_email', email);

        // Reset after 3 seconds
        setTimeout(() => {
          button.textContent = originalText;
          button.disabled = false;
          button.classList.remove('success');
        }, 3000);

      } catch (error) {
        console.error('Subscription error:', error);
        button.textContent = 'error - try again';

        setTimeout(() => {
          button.textContent = originalText;
          button.disabled = false;
        }, 3000);
      }
    }

    // Handle navbar newsletter form
    const navNewsletterForm = document.getElementById('nav-newsletter-form');
    if (navNewsletterForm) {
      navNewsletterForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const emailInput = navNewsletterForm.querySelector('input[type="email"]');
        const button = navNewsletterForm.querySelector('button[type="submit"]');
        await handleNewsletterSubmit(navNewsletterForm, emailInput, button);
      });
    }

    // Handle footer newsletter form
    const footerForm = document.getElementById('newsletter-form');
    if (footerForm) {
      footerForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const emailInput = footerForm.querySelector('input[type="email"]');
        const button = footerForm.querySelector('button[type="submit"]');
        await handleNewsletterSubmit(footerForm, emailInput, button);
      });
    }
  });
</script>
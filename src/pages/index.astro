---
import BaseLayout from "../layouts/BaseLayout.astro";
import RecipeCard from "../components/RecipeCard.astro";
import { getCollection } from "astro:content";

const allRecipes = await getCollection("recipes", ({ data }) => !data.draft);
const recipes = allRecipes.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout>
  <!-- Hero -->
  <section class="max-w-3xl mx-auto px-4 py-16 text-center">
    <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">
      No fluff. Just <span class="text-coral">cook this</span>.
    </h1>
    <p class="text-gray-mid text-lg max-w-xl mx-auto">
      Easy, delicious recipes for couples and families. No ads, no life stories, no endless scrolling. Just the recipe.
    </p>
  </section>

  <!-- Recipe grid -->
  <section class="max-w-3xl mx-auto px-4 pb-16">
    <h2 class="text-sm font-medium uppercase tracking-wide text-gray-mid mb-6">Latest Recipes</h2>
    {recipes.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {recipes.map((recipe) => (
          <RecipeCard
            title={recipe.data.title}
            description={recipe.data.description}
            slug={recipe.id}
            prepTime={recipe.data.prepTime}
            cookTime={recipe.data.cookTime}
            category={recipe.data.category}
            image={recipe.data.image}
            imageAlt={recipe.data.imageAlt}
          />
        ))}
      </div>
    ) : (
      <p class="text-gray-mid text-center py-12">Recipes coming soon.</p>
    )}
  </section>
</BaseLayout>

{
  "name": "cookthis",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && npm run pagefind && cp -r public/admin dist/",
    "pagefind": "pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "tinacms:dev": "tinacms dev -c 'astro dev'",
    "tinacms:build": "tinacms build && astro build"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.0",
    "astro": "^5.17.1",
    "tailwindcss": "^4.2.0"
  },
  "devDependencies": {
    "@tinacms/cli": "^2.1.6",
    "pagefind": "^1.4.0",
    "tinacms": "^3.5.0"
  }
}
